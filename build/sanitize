#! /bin/sh
# build/sanitize — cross-compile the sanitize CLI (linux/amd64) with the version
# and revision stamped into cmd's main.Version / main.Revision (shown in the
# CLI usage report), then optionally scp it to a host and install it.
#
#   build/sanitize [user@host]
#
# With no host argument the binary is left under build/install/. A host can
# also come from the build/host file. An unstamped build (plain go run or
# go build) reports "dev unknown" in the usage line.

BINARY=sanitize
SERVER=$1
if [ -z "$SERVER" ]; then
    SERVERFILE=build/host
    if [ -e "$SERVERFILE" ]; then
        SERVER=$(cat "$SERVERFILE")
    fi
fi

BUILD=$PWD/build
INSTALL=$BUILD/install

if [ -e $INSTALL ]; then
    rm -fr $INSTALL
fi
mkdir $INSTALL


echo "======== SANITIZE ========"
VERSION="$(git describe --tags --always --dirty 2>/dev/null || echo dev)"
REVISION="$(git rev-parse --short=12 HEAD 2>/dev/null || echo unknown)"

echo "VERSION $VERSION $REVISION"

# build the binary with the stamp; cmd/main.go declares main.Version and
# main.Revision for exactly this -X injection
echo "BUILD $BINARY"
GOWORK=off GOOS=linux GOARCH=amd64 go build -trimpath \
  -ldflags "-X 'main.Version=$VERSION' -X 'main.Revision=$REVISION'" \
  -o $INSTALL/$BINARY ./cmd


if [ -n "$SERVER" ]; then
    echo "TRANSMIT to $SERVER"
    scp $INSTALL/$BINARY* $SERVER:

    echo "RUN $SERVER"
    ssh $SERVER "sudo mv $BINARY* /usr/local/bin"

    echo "CLEANUP"
    rm -fr $INSTALL
fi

echo "bye"
